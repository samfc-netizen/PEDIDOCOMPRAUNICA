# Copie este conteudo para .streamlit/secrets.toml no ambiente local
# ou cole este bloco em "Secrets" no Streamlit Cloud.
#
# Use OAuth da conta dona do Drive: gdautotintas@gmail.com.
# Nao use Service Account para criar Google Sheets nativos neste fluxo.

[google_oauth_user]
client_id = "SEU_CLIENT_ID.apps.googleusercontent.com"
client_secret = "SEU_CLIENT_SECRET"
refresh_token = "REFRESH_TOKEN_DA_CONTA_GDAUTOTINTAS"
token_uri = "https://oauth2.googleapis.com/token"
